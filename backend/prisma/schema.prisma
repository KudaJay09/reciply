generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
}

enum Role {
  ADMIN
  MANAGER
  STAFF
  KITCHEN
  CUSTOMER
}

model User {
  id               String   @id @map("_id")
  name             String
  email            String   @unique
  emailVerified    Boolean? @default(false)
  image            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  twoFactorEnabled Boolean? @default(false)
  username         String?  @unique
  displayUsername  String?
  role             Role     @default(CUSTOMER)
  status           String   @default("active")
  // suspended
  age              Int?
  gender           String?
  phone            String?
  banned           Boolean  @default(false)
  banReason        String?

  // Relations
  sessions      Session[]
  accounts      Account[]
  twoFactors    TwoFactor[]
  activitiesLog activitiesLog[]

  @@map("user")
}

model Session {
  id        String   @id @map("_id")
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @map("_id")
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @map("_id")
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model TwoFactor {
  id                      String    @id @map("_id")
  userId                  String
  secret                  String
  backupCodes             String
  verified                Boolean
  failedVerificationCount Int       @default(0)
  lockedUntil             DateTime?
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([secret])
  @@map("twoFactor")
}

model Category {
  id    String     @id @default(auto()) @map("_id") @db.ObjectId
  name  String     @unique
  slug  String     @unique
  items menuItem[]
}

model activitiesLog {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  action    String
  details   String?
  createdAt DateTime   @default(now())
  menuItems menuItem[]
}

model menuItem {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  description     Json?
  price           Float
  discount        Float?         @default(0)
  image           String?
  isAvailable     Boolean        @default(true)
  recipe          String?
  aiSuggestion    String?
  categoryId      String         @db.ObjectId
  category        Category       @relation(fields: [categoryId], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  activitiesLog   activitiesLog? @relation(fields: [activitiesLogId], references: [id])
  activitiesLogId String?        @db.ObjectId
}
